{
  "name": "vitalearn-nexus",
  "version": "1.0.0",
  "description": "Multi-role school healthcare management system",
  "scripts": {
    "start": "node backend/server.js",
    "server": "npm run start --prefix backend",
    "client": "npm run dev --prefix frontend",
    "build": "npm install --prefix frontend && npm run build --prefix frontend && npm install --prefix backend",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "author": "VitaLearn Nexus Team",
  "license": "MIT"
}
